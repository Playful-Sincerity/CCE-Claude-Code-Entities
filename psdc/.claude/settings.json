        "~/.claude/projects"
      ],
      "denyWrite": [
        "~/.claude/CLAUDE.md",
        "~/.claude/settings.json",
        "~/.claude/rules",
        "~/.claude/skills",
        "~/.claude/scripts",
        "~/claude-system",
